<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pilih Hari Ujian</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background-color: #f4f4f9;
      margin: 0;
      padding: 0;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
    }
    .container {
      width: 90%;
      max-width: 400px;
      text-align: center;
      background: #fff;
      padding: 20px;
      border-radius: 10px;
      box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }
    h1 {
      font-size: 1.5rem;
      color: #333;
      margin-bottom: 15px;
    }
    p {
      font-size: 1rem;
      margin-bottom: 20px;
    }
    .btn {
      display: block;
      width: 80%;          /* fleksibel mengikuti layar */
      max-width: 250px;    /* batas maksimal agar tidak terlalu lebar */
      margin: 10px auto;   /* tombol rata tengah */
      padding: 14px;
      background-color: #007bff;
      color: #fff;
      text-decoration: none;
      border-radius: 6px;
      font-size: 1rem;
      transition: 0.3s;
    }
    .btn:hover {
      background-color: #0056b3;
      transform: scale(1.02);
    }
    /* Responsif untuk layar kecil */
    @media (max-width: 480px) {
      h1 {
        font-size: 1.2rem;
      }
      .btn {
        width: 100%;       /* di layar HP tombol full width */
        font-size: 0.9rem;
        padding: 12px;
      }
    }
  </style>
</head>
<body>

  <div class="container">
    <h1>Pilih Hari Ujian</h1>
    <p>Silakan pilih hari ujian Anda:</p>

    <a href="ujian-senin.html" class="btn">Senin</a>
    <a href="ujian-selasa.html" class="btn">Selasa</a>
    <a href="ujian-rabu.html" class="btn">Rabu</a>
    <a href="ujian-kamis.html" class="btn">Kamis</a>
  </div>

</body>
</html>
